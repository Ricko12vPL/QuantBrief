# Mistral AI
MISTRAL_API_KEY=your_mistral_api_key

# ElevenLabs
ELEVENLABS_API_KEY=your_elevenlabs_api_key

# Data Sources
ALPHA_VANTAGE_API_KEY=your_alpha_vantage_key
FINNHUB_API_KEY=your_finnhub_key
FRED_API_KEY=your_fred_key

# SEC EDGAR (required: email in User-Agent)
SEC_USER_AGENT=QuantBrief your_email@example.com

# Redis
REDIS_URL=redis://localhost:6379

# W&B (optional)
WANDB_API_KEY=your_wandb_key
WANDB_PROJECT=quantbrief

# Model Configuration (optional overrides)
# MODEL_SCREENING=ministral-3b-latest
# MODEL_ANALYSIS=mistral-large-latest
# MODEL_REASONING=magistral-medium-latest
# MODEL_SYNTHESIS=mistral-large-latest
# MODEL_TRANSCRIPTION=mistral-large-latest

# App
DEBUG=false
